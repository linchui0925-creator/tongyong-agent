
# ==============================================
# MCP (Model Context Protocol) 配置
# ==============================================
# 启用Playwright浏览器自动化MCP服务
# MCP_SERVERS_PLAYWRIGHT_COMMAND: 启动命令
# MCP_SERVERS_PLAYWRIGHT_ARGS: 启动参数
# MCP_SERVERS_PLAYWRIGHT_ENV: 环境变量
MCP_SERVERS_PLAYWRIGHT_COMMAND="python3"
MCP_SERVERS_PLAYWRIGHT_ARGS=["./mcp_servers/playwright/server.py"]
MCP_SERVERS_PLAYWRIGHT_ENV={}

# 你可以添加更多自定义MCP服务，配置格式：
# MCP_SERVERS_<服务ID>_COMMAND="启动命令"
# MCP_SERVERS_<服务ID>_ARGS=["参数1", "参数2"]
# MCP_SERVERS_<服务ID>_ENV={"KEY": "VALUE"}
