# TongYong Agent 配置
# 复制此文件为 .env 并填写实际值

# 应用配置
APP_NAME=TongYong Agent
DEBUG=true

# 数据库
DATABASE_URL=sqlite:///./data/tongyong.db

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./data/chroma

# LLM 配置（从环境变量读取，不存储在 JSON 配置文件中）
DEFAULT_LLM_PROVIDER=tongyi
TONGYI_API_KEY=your-tongyi-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
MINIMAX_API_KEY=your-minimax-api-key
MOONSHOT_API_KEY=your-moonshot-api-key
STEPFUN_API_KEY=your-stepfun-api-key
SILICONFLOW_API_KEY=your-siliconflow-api-key

# 记忆配置
MEMORY_TOP_K=10
COMPRESS_THRESHOLD=5000
