# 邮件服务配置（联系表单通知）
# 普通SMTP配置（Gmail/Outlook/企业邮箱）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM="TongYong Agent <noreply@your-domain.com>"
SMTP_SSL=false
SMTP_TLS=true

# 联系表单专用配置（可选，覆盖通用SMTP）
# CONTACT_EMAIL_TO=your-notification-inbox@example.com
# CONTACT_SMTP_HOST=
# CONTACT_SMTP_PORT=
# CONTACT_SMTP_USERNAME=
# CONTACT_SMTP_PASSWORD=
# CONTACT_SMTP_FROM=
# CONTACT_SMTP_SSL=
# CONTACT_SMTP_TLS=
# CONTACT_SMTP_TIMEOUT=10

# 防刷配置（可选）
# CONTACT_RATE_LIMIT_PER_MINUTE=5
